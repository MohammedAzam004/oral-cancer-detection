# Optional custom model path
# MODEL_PATH=models/EfficientNetV2S_mouth_cancer.keras

# Optional evaluation dataset with labeled folders such as:
# evaluation/
#   cancer/
#   non_cancer/
# EVAL_DATASET_DIR=C:/path/to/your/evaluation

# Optional metrics report
# By default the app can use: reports/training_report.json
# METRICS_REPORT_PATH=reports/training_report.json

# Streamlit Configuration (Optional)
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=localhost
